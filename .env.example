# ── Database ──────────────────────────────────────────────────────────────────
# Local (non-Docker): full connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fuelmonitor

# Docker Compose: only the password is needed; the URL is built in docker-compose.yml
POSTGRES_PASSWORD=yourpassword

# ── API Keys ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── SMTP (for alert email notifications) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_USE_TLS=true
SMTP_FROM=alerts@fuelmonitor.com
MANAGER_EMAIL=manager@example.com
